# proxy.py が読む環境変数（ZENRIN Maps API + PostgreSQL）
# 実値を入れた .env を作って `set -a; source .env; set +a` で読み込んでから
# `.venv/bin/python proxy.py 8000` を起動する。

# ----- PostgreSQL（データ API の永続化先） -----
# docker compose up -d で起動するローカル Postgres の既定値。
# 別のサーバを使う場合のみ変更する。
DATABASE_URL=postgresql://chiban:chiban@localhost:5432/chiban

# 認証方式: oauth | referer | ip
ZENRIN_AUTH_TYPE=oauth

# ----- OAuth2.0 を使う場合（推奨） -----
# ZENRIN コンソールで発行された client_id / client_secret
ZENRIN_CLIENT_ID=your_client_id_here
ZENRIN_CLIENT_SECRET=your_client_secret_here

# トークン取得エンドポイント（タイル配信ドメインとは別ドメインなので注意。
# テスト環境は test-auth.zmaps-api.com）
ZENRIN_TOKEN_URL=https://test-auth.zmaps-api.com/oauth2/token

# x-api-key（OAuth と併用する契約の場合に必須）
ZENRIN_API_KEY=your_api_key_here

# ----- IP / Referer 制限を使う場合 -----
# ZENRIN_REFERER=http://localhost:8000/

# ----- 共通 -----
# タイル配信ドメイン（テスト環境 / 本番環境を切り替え）
ZENRIN_DOMAIN=test-web.zmaps-api.com

# マップタイプ識別子（ZENRIN ドキュメントの maptype 一覧から契約に合うものを選ぶ。
# 例：
#   hWeH6ZPY  標準地図
#   JPZsAULY  標準地図モノクロ
#   ZpcFaeMB  住宅地図（ブルーマップ、契約必要）
#   XDwDmdBN  住宅地図モノクロ（契約必要）
# 契約していないマップタイプを指定すると 400 エラーになる）
ZENRIN_LAYER=hWeH6ZPY

# スタイル: default | highres
ZENRIN_STYLE=default
