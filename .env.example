# Next.js（App Router）が読む環境変数（ZENRIN Maps API + PostgreSQL）
# 実値を入れた .env（または .env.local）を作成すると Next.js が自動で読み込む。
# `docker compose up -d` で PostgreSQL を起動してから `npm run dev` で起動する。

# ----- PostgreSQL（データ API の永続化先） -----
# docker compose up -d で起動するローカル Postgres の既定値。
# 別のサーバを使う場合のみ変更する。
DATABASE_URL=postgresql://chiban:chiban@localhost:5432/chiban

# ----- ZENRIN Maps API（ログイン認証 / zip-site.com 系） -----
# ZENRIN から発行された「ユーザーID・パスワード」で認証サーバにログインし、
# 取得した認証情報（aid/kid）でタイルを取得する方式。

# ログイン資格情報（ZENRIN から案内される値）。service_id は必須。
ZENRIN_USER_ID=your_user_id_here
ZENRIN_PASSWORD=your_password_here
ZENRIN_SERVICE_ID=your_service_id_here

# device_flag はログインAPIの必須パラメータ。固定値 "1" を指定する（省略時も "1"）。
# ZENRIN_DEVICE_FLAG=1

# 認証サーバ（login/logout）・WMTS タイル配信のドメイン。
# 既定は検証環境。本番環境では api.zip-site.com / wmts.zip-site.com を指定する。
ZENRIN_LOGIN_DOMAIN=test-api.zip-site.com
ZENRIN_WMTS_DOMAIN=test-wmts.zip-site.com

# ラスター配信用マップタイプ識別子（契約に対応する値を ZENRIN から確認して設定）。
ZENRIN_LAYER=default

# スタイル: default | highres
ZENRIN_STYLE=default

# セッション再ログイン間隔（秒）。同時ログイン数=1・自動/強制タイムアウト(30/60分)のため、
# 強制タイムアウトより手前で張り直す（既定 1500=25分）。
# ZENRIN_SESSION_TTL_SEC=1500
