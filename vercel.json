{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/tile/:z/:x/:y.png",
      "destination": "/api/tile?z=:z&x=:x&y=:y"
    }
  ],
  "headers": [
    {
      "source": "/tile/:z/:x/:y.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
